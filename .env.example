# Razorpay Credentials (for INR payments)
# Get these from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Stripe Credentials (for USD/EUR international payments)
# Get these from https://dashboard.stripe.com/apikeys
# After adding the key, enable PayPal in Stripe Dashboard → Settings → Payment methods
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here

# Base URL for Stripe redirect (your production domain)
BASE_URL=https://youdeservewell.com

# Email Configuration (for sending download links)
# Using Gmail SMTP as example
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password_here

# Vercel URL (auto-set by Vercel, no need to manually configure)
VERCEL_URL=
